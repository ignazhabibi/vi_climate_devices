{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "ignoreDeps": [
    "pytest"
  ],
  "separateMinorPatch": true,
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions"
    },
    {
      "matchPackageNames": [
        "ignazhabibi/vi_api_client"
      ],
      "groupName": "vi_api_client"
    },
    {
      "matchPackageNames": [
        "pytest-asyncio",
        "pytest-homeassistant-custom-component",
        "syrupy"
      ],
      "groupName": "python test stack"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)pyproject\\.toml$/",
        "/(^|/)custom_components/vi_climate_devices/manifest\\.json$/"
      ],
      "matchStrings": [
        "vi_api_client @ git\\+https://github\\.com/(?<depName>[^/]+/[^.]+)\\.git@(?<currentValue>v[^\"\\s,\\]]+)"
      ],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver-coerced"
    }
  ]
}
