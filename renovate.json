{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "separateMinorPatch": true,
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions"
    },
    {
      "matchPackageNames": [
        "pytest-homeassistant-custom-component"
      ],
      "matchNewValue": "0.13.320",
      "enabled": false
    },
    {
      "matchPackageNames": [
        "ignazhabibi/vi_api_client"
      ],
      "groupName": "vi_api_client"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)pyproject\\.toml$/",
        "/(^|/)custom_components/vi_climate_devices/manifest\\.json$/"
      ],
      "matchStrings": [
        "vi_api_client @ git\\+https://github\\.com/(?<depName>[^/]+/[^.]+)\\.git@(?<currentValue>v[^\"\\s,\\]]+)"
      ],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver-coerced"
    }
  ]
}
